{
  "name": "update-static-assets",
  "version": "4.0.3",
  "private": true,
  "description": "A GitHub Action that updates HTML static assets.",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write eslint.config.mjs src/**/*.ts tests/**/*.ts",
    "format-check": "prettier --check eslint.config.mjs src/**/*.ts tests/**/*.ts",
    "generate": "npm run build && npm run package",
    "lint": "eslint src/**/*.ts --fix",
    "package": "node esbuild.config.mjs",
    "test": "vitest run",
    "publish": "npm run format && npm run lint && npm run generate",
    "all": "npm run publish && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martincostello/update-static-assets.git"
  },
  "keywords": [
    "actions",
    "assets",
    "css",
    "github",
    "html",
    "javascript",
    "static",
    "update"
  ],
  "author": {
    "name": "Martin Costello",
    "url": "https://martincostello.com/"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/martincostello/update-static-assets/issues"
  },
  "homepage": "https://github.com/martincostello/update-static-assets#readme",
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1",
    "@actions/io": "3.0.2",
    "@octokit/plugin-paginate-rest": "14.0.0",
    "@octokit/plugin-rest-endpoint-methods": "17.0.0",
    "glob": "13.0.6",
    "jsdom": "29.1.1",
    "lru-cache": "11.5.2",
    "undici": "8.7.0",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "10.0.1",
    "@octokit/types": "16.0.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "25.9.5",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.22",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-plugin-github": "6.1.1",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "printWidth": 80,
    "quoteProps": "consistent",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
